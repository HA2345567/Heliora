generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// USERS & AGENTS
// ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  wallet        String    @unique
  handle        String?   @unique
  createdAt     DateTime  @default(now())
  positions     Position[]
  trades        Trade[]
  createdMarkets Market[] @relation("MarketCreator")
  subscriptions AgentSubscription[]
}

enum AgentType {
  Sentiment
  Arbitrage
  MarketMaker
  NewsAlpha
  Momentum
}

enum AgentStatus {
  live
  paused
}

model Agent {
  id              String   @id @default(cuid())
  name            String
  handle          String   @unique
  wallet          String   @unique
  type            AgentType
  description     String
  pnl30d          Float    @default(0)
  winRate         Float    @default(0)
  sharpe          Float    @default(0)
  maxDrawdown     Float    @default(0)
  aum             Float    @default(0)
  performanceFee  Float    @default(15)
  uptime          Float    @default(99.9)
  marketsTraded   Int      @default(0)
  status          AgentStatus @default(live)
  createdAt       DateTime @default(now())
  subscriptions   AgentSubscription[]
  oracleVotes     OracleVote[]
}

model AgentSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  agent     Agent    @relation(fields: [agentId], references: [id])
  agentId   String
  capital   Float
  createdAt DateTime @default(now())

  @@unique([userId, agentId])
}

// ──────────────────────────────────────────────────────────────
// MARKETS
// ──────────────────────────────────────────────────────────────

enum MarketCategory {
  Crypto
  Politics
  Sports
  Memes
  NFTs
  DeFi
  Social
  AI
}

enum ResolutionSource {
  Pyth
  Switchboard
  AIOracle
  DAOVote
}

enum MarketStatus {
  open
  resolving
  resolved
  disputed
}

enum Outcome {
  YES
  NO
  INVALID
}

model Market {
  id              String           @id @default(cuid())
  onchainId       String?          @unique // Solana account pubkey once deployed
  question        String
  description     String?
  category        MarketCategory
  resolution      ResolutionSource
  resolutionDetail String?
  endsAt          DateTime
  resolvedAt      DateTime?
  status          MarketStatus     @default(open)
  outcome         Outcome?
  yesPrice        Float            @default(0.5)
  noPrice         Float            @default(0.5)
  liquidity       Float            @default(0)
  volume          Float            @default(0)
  participants    Int              @default(0)
  isLive          Boolean          @default(false)
  creator         User             @relation("MarketCreator", fields: [creatorId], references: [id])
  creatorId       String
  createdAt       DateTime         @default(now())

  trades          Trade[]
  positions       Position[]
  pricePoints     PricePoint[]
  oracleResolution OracleResolution?

  @@index([category, status])
  @@index([endsAt])
}

model PricePoint {
  id        String   @id @default(cuid())
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId  String
  yesPrice  Float
  noPrice   Float
  ts        DateTime @default(now())

  @@index([marketId, ts])
}

// ──────────────────────────────────────────────────────────────
// TRADING
// ──────────────────────────────────────────────────────────────

enum Side {
  YES
  NO
}

enum TradeKind {
  market
  limit
  stop
}

model Trade {
  id        String    @id @default(cuid())
  market    Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId  String
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  side      Side
  kind      TradeKind @default(market)
  shares    Float
  price     Float
  cost      Float
  txSig     String?   // on-chain signature when applicable
  createdAt DateTime  @default(now())

  @@index([marketId, createdAt])
  @@index([userId])
}

model Position {
  id         String   @id @default(cuid())
  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId   String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  yesShares  Float    @default(0)
  noShares   Float    @default(0)
  avgYesCost Float    @default(0)
  avgNoCost  Float    @default(0)
  realizedPnl Float   @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([marketId, userId])
}

// ──────────────────────────────────────────────────────────────
// AI ORACLE
// ──────────────────────────────────────────────────────────────

model OracleResolution {
  id         String   @id @default(cuid())
  market     Market   @relation(fields: [marketId], references: [id])
  marketId   String   @unique
  outcome    Outcome
  consensus  Int      // votes that matched outcome
  totalVotes Int
  reasoning  String?  // AI summary
  createdAt  DateTime @default(now())
  votes      OracleVote[]
}

model OracleVote {
  id            String   @id @default(cuid())
  resolution    OracleResolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  resolutionId  String
  agent         Agent    @relation(fields: [agentId], references: [id])
  agentId       String
  vote          Outcome
  confidence    Float
  evidence      String?
  createdAt     DateTime @default(now())

  @@unique([resolutionId, agentId])
}
