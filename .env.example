# Heliora frontend env (Vite). Copy to `.env` and fill in.

# Backend API base URL (the Express server in /backend)
VITE_API_URL=http://localhost:4000

# Solana RPC. Devnet by default; swap for Helius/Triton in prod.
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Deployed Heliora Anchor program id (set after `anchor deploy`)
VITE_HELIORA_PROGRAM_ID=Helioraxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
